# =========================================================
# OS / System files
# =========================================================
.DS_Store
Thumbs.db
desktop.ini


# =========================================================
# IDE / Editor files
# =========================================================
.idea/
.vscode/
*.iml
*.ipr
*.iws


# =========================================================
# Python / Flask generated files
# =========================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/


# =========================================================
# Python virtual environments
# =========================================================
venv/
env/
.venv/
ENV/


# =========================================================
# Environment variables / secrets
# =========================================================
.env
.env.*
instance/

# Keep example env files if you create them
!.env.example


# =========================================================
# Logs / runtime output
# =========================================================
*.log
logs/
data/logs/
flask_flutter_phase1_backend/data/logs/


# =========================================================
# Backups / exports / temporary files
# =========================================================
backups/
data/backups/
data/exports/
flask_flutter_phase1_backend/backups/
flask_flutter_phase1_backend/data/backups/
flask_flutter_phase1_backend/data/exports/

*.bak
*.tmp
*.temp
*.old


# =========================================================
# PyInstaller / Python build outputs
# =========================================================
build/
dist/
*.exe
*.dll
*.pyd
*.manifest

# Keep your actual PyInstaller spec if you use it
!app.spec
!flask_flutter_phase1_backend/app.spec


# =========================================================
# Flutter / Dart generated files
# =========================================================
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/build/
**/coverage/


# =========================================================
# Flutter generated plugin/platform cache
# Very important: this removes huge generated plugin folders
# =========================================================
**/Flutter/ephemeral/
**/flutter/ephemeral/
**/.plugin_symlinks/


# =========================================================
# Flutter generated registrant files
# Usually regenerated by flutter pub get/build
# =========================================================
**/generated_plugin_registrant.*
**/GeneratedPluginRegistrant.*


# =========================================================
# Flutter local machine files
# =========================================================
**/local.properties


# =========================================================
# Node / Electron old generated files
# =========================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
package.json

# =========================================================
# Archives / shared patches
# =========================================================
*.zip
*.rar
*.7z
*.tar
*.gz
/flask_flutter_phase1_backend
/anime_tag_tools
folder_structure.txt
map.py